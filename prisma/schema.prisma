generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                     Int               @id @default(autoincrement())
  sku                    String
  name                   String
  comercial_name         String
  category               String
  origin_country         String
  price_comercial        Float
  price_local            Float
  currency               String
  comission              Float
  incoterm               String[]
  regulator_organ_number String
  sanity_rules           String[]
  pack_type              String
  quantity_per_pack      Float
  quantity_per_container Float
  container_type         String
  country_from           String
  supply_origin_country  String
  port_origin            String
  port_destination       String
  documents_required     String[]
  record_owner           String
  observation            String
  attached_files         String[]
  sellers                Seller            @relation(fields: [sellersId], references: [id])
  sellersId              Int               @default(0)
  contracts              Contract[]        @relation("ContractProduct")
  contractProducts       ContractProduct[]
  createdAt              DateTime          @default(now())
  active                 Boolean           @default(true)
  status                 String
}

model Seller {
  id           Int        @id @default(autoincrement())
  company_name String
  full_address String
  country      String
  tax_id       String
  contact_name String
  whatsapp     String
  phone        String[]
  email        String[]
  website      String
  note         String
  description  String
  products     Product[]
  contracts    Contract[]
  createdAt    DateTime   @default(now())
  active       Boolean    @default(true)
  status       String
}

model Client {
  id           Int        @id @default(autoincrement())
  name         String
  full_name    String
  full_address String
  country      String
  tax_id       String
  contact_name String
  whatsapp     String
  phone        String[]
  email        String[]
  website      String
  note         String
  description  String
  contracts    Contract[]
  createdAt    DateTime   @default(now())
  active       Boolean    @default(true)
  status       String
}

model Contract {
  id                               Int                @id @default(autoincrement())
  name                             String
  description                      String
  date_creation                    DateTime
  date_expiration                  DateTime
  date_signature                   DateTime
  date_expiration_signature        DateTime
  date_signature_client            DateTime
  date_expiration_signature_client DateTime
  date_signature_seller            DateTime
  date_expiration_signature_seller DateTime
  client_id                        Int
  client                           Client             @relation(fields: [client_id], references: [id])
  seller_id                        Int
  seller                           Seller             @relation(fields: [seller_id], references: [id])
  products_id                      Int[]
  products                         Product[]          @relation("ContractProduct")
  contractProducts                 ContractProduct[]
  bording_date                     DateTime
  mt_value                         Float
  destination_country              String
  destination_port                 String
  shipping_company                 String
  shipment_date                    DateTime
  si_sent                          Boolean
  packing                          String[]
  arbitration_rules                ArbitrationRule[]
  special_conditions               SpecialCondition[]
  incoterm                         String[]
  payment_terms                    String
  payment_method                   String
  payment_currency                 String
  payment_amount                   Float
  payment_date                     DateTime
  payment_status                   String
  payment_notes                    String
  payment_attachments              String[]
  payment_notes_client             String
  payment_attachments_client       String[]
  payment_notes_seller             String
  payment_attachments_seller       String[]
  special_terms                    String[]
  business_terms                   String[]
  legal_terms                      String[]
  other_terms                      String[]
  other_terms_client               String[]
  other_terms_seller               String[]
  other_terms_client_seller        String[]
  other_terms_seller_client        String[]
  other_terms_client_seller_client String[]
  other_terms_seller_client_seller String[]
  commission_client                Float
  commission_seller                Float
  comission_total                  Float
  attachments                      String[]
  createdAt                        DateTime           @default(now())
  active                           Boolean            @default(true)
  status                           String
  brokerageInvoices                BrokerageInvoice[]
}

model ContractProduct {
  id          Int      @id @default(autoincrement())
  contract_id Int
  contract    Contract @relation(fields: [contract_id], references: [id])
  product_id  Int
  product     Product  @relation(fields: [product_id], references: [id])
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)
  status      String
}

model BrokerageInvoice {
  id                  Int      @id @default(autoincrement())
  contract_id         Int
  contract            Contract @relation(fields: [contract_id], references: [id])
  comission_total_usd Float
  comission_total_brl Float
  bl_date             DateTime
  bl_number           String
  bl_attachments      String[]
  ptax                Float
  attachments         String[]
  createdAt           DateTime @default(now())
  active              Boolean  @default(true)
  status              String
}

model ArbitrationRule {
  id          Int        @id @default(autoincrement())
  name        String
  description String
  order       Int
  type        String
  note        String
  attachments String[]
  contracts   Contract[]
  createdAt   DateTime   @default(now())
  active      Boolean    @default(true)
  status      String
}

model SpecialCondition {
  id          Int        @id @default(autoincrement())
  name        String
  description String
  tags        String[]
  type        String
  note        String
  attachments String[]
  order       Int
  contracts   Contract[]
  createdAt   DateTime   @default(now())
  active      Boolean    @default(true)
  status      String
}
