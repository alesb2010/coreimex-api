generator customer {
  provider      = "prisma-client-js"
  output        = "../generated/prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BankAccount {
  id                Int                @id @default(autoincrement())
  bank_name         String
  account_holder    String
  account_number    String?
  agency            String?
  account_type      String             @default("checking")
  swift_bic         String?
  iban              String?
  pix_key           String?
  currency          String             @default("BRL")
  notes             String?
  createdAt         DateTime           @default(now())
  active            Boolean            @default(true)
  status            String             @default("active")
  deleted           Boolean            @default(false)
  BrokerageInvoices BrokerageInvoice[]
}

model ArbitrationRule {
  id          Int        @id @default(autoincrement())
  name        String
  description String
  order       Int
  type        String
  note        String
  attachments String[]
  createdAt   DateTime   @default(now())
  active      Boolean    @default(true)
  status      String
  deleted     Boolean    @default(false)
  Contract    Contract[]
}

model BrokerageInvoice {
  id                    Int                    @id @default(autoincrement())
  number                String?
  invoice_date          DateTime?
  sent_date             DateTime?
  expected_payment_date DateTime?
  received_date         DateTime?
  createdAt             DateTime               @default(now())
  active                Boolean                @default(true)
  status                String
  deleted               Boolean                @default(false)
  bank_account_id       Int?
  BankAccount           BankAccount?           @relation(fields: [bank_account_id], references: [id], onDelete: SetNull)
  Lines                 BrokerageInvoiceLine[]
}

model BrokerageInvoiceLine {
  id                   Int              @id @default(autoincrement())
  brokerage_invoice_id Int
  contract_id          Int
  bl_date              DateTime
  bl_number            String
  bl_attachments       String[]
  comission_total_usd  Float
  ptax                 Float            @default(0)
  comission_total_brl  Float            @default(0)
  description          String           @default("")
  notes                String           @default("")
  attachments          String[]
  createdAt            DateTime         @default(now())
  active               Boolean          @default(true)
  status               String
  deleted              Boolean          @default(false)
  BrokerageInvoice     BrokerageInvoice @relation(fields: [brokerage_invoice_id], references: [id], onDelete: Cascade)
  Contract             Contract         @relation(fields: [contract_id], references: [id])

  @@unique([brokerage_invoice_id, contract_id])
}

model Contact {
  id           Int       @id @default(autoincrement())
  position     String?
  whatsapp     String?
  customer_id  Int?
  seller_id    Int?
  createdAt    DateTime  @default(now())
  active       Boolean   @default(true)
  status       String    @default("active")
  address      String?
  city         String?
  company_name String?
  country      String?
  description  String?
  first_name   String
  full_name    String?
  last_name    String
  notes        String?
  state        String?
  zip_code     String?
  email        Json?
  phone        Json?
  deleted      Boolean   @default(false)
  Customer     Customer? @relation(fields: [customer_id], references: [id])
  Seller       Seller?   @relation(fields: [seller_id], references: [id])
}

model Contract {
  id                                  Int                    @id @default(autoincrement())
  name                                String
  description                         String
  date_creation                       DateTime?
  date_expiration                     DateTime?
  date_signature                      DateTime?
  date_expiration_signature           DateTime?
  date_signature_party_a              DateTime?
  date_expiration_signature_party_a   DateTime?
  date_signature_party_b              DateTime?
  date_expiration_signature_party_b   DateTime?
  customer_party_a_id                 Int
  customer_party_b_id                 Int
  products_id                         Int[]
  bording_date                        DateTime?
  mt_value                            Float
  origin_country                      String?
  origin_port                         String?
  destination_country                 String
  destination_port                    String
  shipping_company                    String
  shipment_date                       DateTime?
  si_sent                             Boolean
  packing                             String[]
  incoterm                            String[]
  payment_terms                       String
  payment_method                      String
  payment_currency                    String
  payment_amount                      Float
  payment_date                        DateTime?
  payment_status                      String
  payment_notes                       String
  payment_attachments                 String[]
  payment_notes_party_a               String
  payment_attachments_party_a         String[]
  payment_notes_party_b               String
  payment_attachments_party_b         String[]
  special_terms                       String[]
  business_terms                      String[]
  legal_terms                         String[]
  other_terms                         String[]
  other_terms_party_a                 String[]
  other_terms_party_b                 String[]
  other_terms_party_a_party_b         String[]
  other_terms_party_a_party_b_party_a String[]
  other_terms_party_b_party_a         String[]
  other_terms_party_b_party_a_party_b String[]
  commission_party_a                  Float
  commission_party_b                  Float
  comission_total                     Float
  attachments                         String[]
  createdAt                           DateTime               @default(now())
  active                              Boolean                @default(true)
  status                              String
  deleted                             Boolean                @default(false)
  BrokerageInvoiceLines               BrokerageInvoiceLine[]
  PartyA                              Customer               @relation("ContractPartyA", fields: [customer_party_a_id], references: [id])
  PartyB                              Customer               @relation("ContractPartyB", fields: [customer_party_b_id], references: [id])
  ContractProduct                     ContractProduct[]
  ArbitrationRule                     ArbitrationRule[]
  Product                             Product[]              @relation("ContractProduct")
  SpecialCondition                    SpecialCondition[]
  ActivityLogs                        ContractActivityLog[]

  @@index([customer_party_a_id])
  @@index([customer_party_b_id])
  @@index([date_creation])
  @@index([status])
}

model ContractActivityLog {
  id                     Int      @id @default(autoincrement())
  contract_id            Int
  action                 String
  details                String?
  reference              String?
  payload                Json?
  actorSuperTokensUserId String?
  actorUserId            Int?
  actorEmail             String?
  createdAt              DateTime @default(now())

  Contract Contract @relation(fields: [contract_id], references: [id], onDelete: Cascade)

  @@index([contract_id, createdAt])
  @@index([actorSuperTokensUserId, createdAt])
}

model ContractProduct {
  id          Int      @id @default(autoincrement())
  contract_id Int
  product_id  Int
  pack_id     Int? // optional reference to Pack used for this product in this contract
  price       Float? // price for this product in this contract
  quantity    Float? // quantity of this product in this contract
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)
  status      String
  deleted     Boolean  @default(false)
  Contract    Contract @relation(fields: [contract_id], references: [id])
  Product     Product  @relation(fields: [product_id], references: [id])
  Pack        Pack?    @relation(fields: [pack_id], references: [id])

  @@index([contract_id])
  @@index([product_id])
}

model Pack {
  id                     Int               @id @default(autoincrement())
  name                   String
  pack_type              String?
  quantity_per_pack      Float?
  quantity_per_container Float?
  container_type         String?
  description            String?
  createdAt              DateTime          @default(now())
  active                 Boolean           @default(true)
  status                 String
  deleted                Boolean           @default(false)
  ContractProducts       ContractProduct[]
}

model Customer {
  id                Int        @id @default(autoincrement())
  name              String
  full_name         String
  full_address      String
  country           String
  tax_id            String
  contact_name      String
  whatsapp          String
  phone             String[]
  email             String[]
  website           String
  note              String
  description       String
  createdAt         DateTime   @default(now())
  active            Boolean    @default(true)
  status            String
  deleted           Boolean    @default(false)
  Contact           Contact[]
  ContractsAsPartyA Contract[] @relation("ContractPartyA")
  ContractsAsPartyB Contract[] @relation("ContractPartyB")
}

model File {
  id         Int      @id @default(autoincrement())
  filename   String
  objectKey  String   @unique
  mimetype   String
  size       Int
  entityType String?
  entityId   Int?
  uploadedBy String?
  createdAt  DateTime @default(now())
  active     Boolean  @default(true)
  deleted    Boolean  @default(false)
  productId  Int?
  Product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
}

model Product {
  id                     Int               @id @default(autoincrement())
  sku                    String
  name                   String
  comercial_name         String
  category               String
  origin_country         String
  price_comercial        Float
  price_local            Float
  comission              Float
  incoterm               String[]
  regulator_organ_number String
  sanity_rules           String[]
  pack_type              String
  quantity_per_pack      Float
  quantity_per_container Float
  container_type         String
  country_from           String
  supply_origin_country  String
  port_origin            String
  port_destination       String
  documents_required     String[]
  record_owner           String
  observation            String
  createdAt              DateTime          @default(now())
  active                 Boolean           @default(true)
  status                 String
  currency               String
  sellersId              Int?
  deleted                Boolean           @default(false)
  ContractProduct        ContractProduct[]
  Seller                 Seller?           @relation(fields: [sellersId], references: [id])
  Contract               Contract[]        @relation("ContractProduct")
  File                   File[]
}

model Seller {
  id           Int       @id @default(autoincrement())
  company_name String
  full_address String
  country      String
  tax_id       String
  contact_name String
  whatsapp     String
  phone        String[]
  email        String[]
  website      String
  note         String
  description  String
  createdAt    DateTime  @default(now())
  active       Boolean   @default(true)
  status       String
  deleted      Boolean   @default(false)
  Contact      Contact[]
  Product      Product[]
}

model SpecialCondition {
  id          Int        @id @default(autoincrement())
  name        String
  description String
  tags        String[]
  type        String
  note        String
  attachments String[]
  order       Int
  createdAt   DateTime   @default(now())
  active      Boolean    @default(true)
  status      String
  deleted     Boolean    @default(false)
  Contract    Contract[]
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  active      Boolean  @default(true)
  deleted     Boolean  @default(false)
}

model User {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  name              String?
  role              String   @default("user")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  superTokensUserId String   @unique
  deleted           Boolean  @default(false)
}
